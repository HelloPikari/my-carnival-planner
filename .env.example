DATABASE_URL=postgres://mcp:mcp@localhost:5432/carnival_planner

# WorkOS AuthKit — get values from https://dashboard.workos.com
WORKOS_CLIENT_ID=client_...
WORKOS_API_KEY=sk_...
# Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=<32+ character random string>
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback

# WorkOS MCP auth
# GOTCHA: use /sso/jwks/ NOT /user_management/jwks/
WORKOS_JWKS_URI=https://api.workos.com/sso/jwks/<WORKOS_CLIENT_ID>
# GOTCHA: must include the client-id path segment
WORKOS_ISSUER=https://api.workos.com/user_management/<WORKOS_CLIENT_ID>
OAUTH_ISSUER=http://localhost:3000

# Admin MCP access (comma-separated emails)
MCP_ADMIN_EMAILS=you@example.com
